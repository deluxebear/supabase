[Unit]
Description=Supabase Backup Host Agent
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
User=root
ExecStart=/usr/local/bin/backup-operator --mode=agent
EnvironmentFile=/etc/backup-operator/agent.env
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/backup-agent /var/lib/postgresql /etc/pgbackrest

[Install]
WantedBy=multi-user.target
